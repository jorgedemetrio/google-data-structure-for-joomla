<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade">
    <name>PLG_CONTENT_ESQUEMARICOKEYWORDS</name>
    <author>Esquema Rico</author>
    <creationDate>2026-06</creationDate>
    <copyright>Copyright (C) 2026 Esquema Rico. Todos os direitos reservados.</copyright>
    <license>GNU General Public License versão 3 ou posterior; ver LICENSE</license>
    <version>1.0.0</version>
    <description>PLG_CONTENT_ESQUEMARICOKEYWORDS_DESC</description>

    <namespace path="src">Joomla\Plugin\Content\Esquemaricokeywords</namespace>

    <files>
        <folder plugin="esquemaricokeywords">services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>

    <languages folder="language">
        <language tag="pt-BR">pt-BR/plg_content_esquemaricokeywords.ini</language>
        <language tag="pt-BR">pt-BR/plg_content_esquemaricokeywords.sys.ini</language>
        <language tag="en-GB">en-GB/plg_content_esquemaricokeywords.ini</language>
        <language tag="en-GB">en-GB/plg_content_esquemaricokeywords.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="include_tags" type="radio" layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_ESQUEMARICOKEYWORDS_INCLUDE_TAGS"
                    description="PLG_CONTENT_ESQUEMARICOKEYWORDS_INCLUDE_TAGS_DESC"
                    default="1">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
