<?xml version="1.0" encoding="utf-8"?>
<!-- Condições de publicação da integração JEvents. -->
<form>
    <fields name="params">
        <fields name="assignments">
            <fieldset name="menu" label="ESR_ASSIGNMENT_MENU">
                <fields name="menu">
                    <field name="assignment_state" type="radio" layout="joomla.form.field.radio.switcher"
                        label="ESR_ASSIGNMENT_MENU" default="0">
                        <option value="0">JNO</option>
                        <option value="1">JYES</option>
                    </field>
                    <field name="operator" type="list" label="ESR_ASSIGNMENT_OPERATOR"
                        default="includes" showon="assignment_state:1">
                        <option value="includes">ESR_ASSIGNMENT_INCLUDES</option>
                        <option value="not_includes">ESR_ASSIGNMENT_NOT_INCLUDES</option>
                    </field>
                    <field name="selection" type="menuitem" multiple="true"
                        label="ESR_ASSIGNMENT_MENU_SELECT" showon="assignment_state:1" />
                    <fields name="params">
                        <field name="include_children" type="radio" layout="joomla.form.field.radio.switcher"
                            label="ESR_ASSIGNMENT_INCLUDE_CHILDREN" default="0" showon="assignment_state:1">
                            <option value="0">JNO</option>
                            <option value="1">JYES</option>
                        </field>
                    </fields>
                </fields>
            </fieldset>

            <fieldset name="idioma" label="ESR_ASSIGNMENT_LANGUAGE">
                <fields name="idioma">
                    <field name="assignment_state" type="radio" layout="joomla.form.field.radio.switcher"
                        label="ESR_ASSIGNMENT_LANGUAGE" default="0">
                        <option value="0">JNO</option>
                        <option value="1">JYES</option>
                    </field>
                    <field name="operator" type="list" label="ESR_ASSIGNMENT_OPERATOR"
                        default="includes" showon="assignment_state:1">
                        <option value="includes">ESR_ASSIGNMENT_INCLUDES</option>
                        <option value="not_includes">ESR_ASSIGNMENT_NOT_INCLUDES</option>
                    </field>
                    <field name="selection" type="contentlanguage" multiple="true"
                        label="ESR_ASSIGNMENT_LANGUAGE_SELECT" showon="assignment_state:1" />
                </fields>
            </fieldset>
        </fields>
    </fields>
</form>
