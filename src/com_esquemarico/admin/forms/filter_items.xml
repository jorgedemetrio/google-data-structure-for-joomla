<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\Esquemarico\Administrator\Field">
    <fields name="filter">
        <field name="search" type="text"
            label="COM_ESQUEMARICO_FILTER_SEARCH"
            hint="JSEARCH_FILTER"
        />
        <field name="published" type="status"
            label="JOPTION_SELECT_PUBLISHED"
            onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
        <field name="plugin" type="integrations"
            label="ESR_ITEM_INTEGRATION"
            onchange="this.form.submit();">
            <option value="">ESR_FILTER_SELECT_INTEGRATION</option>
        </field>
        <field name="contenttype" type="contenttypes"
            label="ESR_ITEM_CONTENT_TYPE"
            onchange="this.form.submit();">
            <option value="">ESR_FILTER_SELECT_TYPE</option>
        </field>
        <field name="language" type="contentlanguage"
            label="JOPTION_SELECT_LANGUAGE"
            onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_LANGUAGE</option>
        </field>
    </fields>

    <fields name="list">
        <field name="fullordering" type="list"
            label="JGLOBAL_SORT_BY"
            default="a.ordering ASC"
            onchange="this.form.submit();">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.title ASC">JGLOBAL_TITLE_ASC</option>
            <option value="a.title DESC">JGLOBAL_TITLE_DESC</option>
            <option value="a.state ASC">JSTATUS_ASC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
            <option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
        </field>
        <field name="limit" type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="20"
            onchange="this.form.submit();"
        />
    </fields>
</form>
