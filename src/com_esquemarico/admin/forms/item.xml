<?xml version="1.0" encoding="utf-8"?>
<!--
    Formulário base do item de marcação.

    Os campos do tipo de conteúdo escolhido (forms/contenttypes/<tipo>.xml) e as
    condições de publicação (form/assignments.xml da integração) são carregados
    dinamicamente pelo modelo (ItemModel::preprocessForm).
-->
<form addfieldprefix="Joomla\Component\Esquemarico\Administrator\Field">
    <fieldset name="geral" label="ESR_ITEM_FIELDSET_GENERAL">
        <field name="id" type="hidden" />

        <field name="title" type="text"
            label="ESR_ITEM_TITLE"
            description="ESR_ITEM_TITLE_DESC"
            required="true"
            size="40"
        />

        <field name="plugin" type="integrations"
            label="ESR_ITEM_INTEGRATION"
            description="ESR_ITEM_INTEGRATION_DESC"
            required="true"
            default=""
        >
            <option value="">ESR_ITEM_SELECT</option>
        </field>

        <field name="contenttype" type="contenttypes"
            label="ESR_ITEM_CONTENT_TYPE"
            description="ESR_ITEM_CONTENT_TYPE_DESC"
            required="true"
            default=""
        >
            <option value="">ESR_ITEM_SELECT</option>
        </field>

        <field name="appview" type="hidden" default="*" />

        <field name="note" type="text"
            label="ESR_ITEM_NOTE"
            description="ESR_ITEM_NOTE_DESC"
            size="40"
        />

        <field name="state" type="list"
            label="JSTATUS"
            default="1">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field name="language" type="contentlanguage"
            label="JFIELD_LANGUAGE_LABEL"
            default="*">
            <option value="*">JALL</option>
        </field>

        <field name="ordering" type="hidden" />
        <field name="created" type="hidden" />
        <field name="created_by" type="hidden" />
    </fieldset>

    <fieldset name="preview" label="ESR_ITEM_FIELDSET_PREVIEW">
        <field name="schema_preview" type="schemapreview" label="" />
    </fieldset>
</form>
